PORT=3000
# Локально: 127.0.0.1. На сервере MySQL должен слушать только localhost (bind-address=127.0.0.1);
# порт 3306 не должен быть открыт в фаерволе в интернет — только SSH/VPN/приватная сеть.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=amnesia_web
MYSQL_PASSWORD=
MYSQL_DATABASE=amnesia_web
# MYSQL_CONNECT_TIMEOUT_MS=15000

# Remnawave (панель) — инфраструктура на главной и детали подписки в ЛК
RW_API_BASE_URL=https://panel.example.com
RW_API_TOKEN=
RW_SUB_BASE=https://sub.example.com

# Вторая БД — та же, что у Telegram-бота (таблица users: user_id = telegram id, balance, remnawave_user_id)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=amnesia_vpn

# Google reCAPTCHA v3 — ключи из https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# Публичный URL сайта (для защищённой ссылки подписки /api/subscription/proxy)
PUBLIC_SITE_URL=https://amnesia.pw
SUBSCRIPTION_LINK_SECRET=
VPN_CONNECT_BASE_URL=https://connect.example.com
HAPP_CRYPTO_API=https://crypto.happ.su/api-v2.php

# Сессия: JWT в cookie amnesia_auth. В production обязателен надёжный секрет (≥32 символов).
JWT_SECRET=

# Тот же секрет, что WEB_BOT_INTERNAL_SECRET на боте — для POST /api/internal/telegram-link
WEB_BOT_INTERNAL_SECRET=

WEB_TELEGRAM_BOT_TOKEN=
WEB_TELEGRAM_BOT_USERNAME=AmnesiaWebBot
WEB_TELEGRAM_WIDGET_ENABLED=1

# Platega: webhook в кабинете Platega указывайте на бота, не на сайт.
# PLATEGA_MERCHANT_ID=
# PLATEGA_SECRET=
# PLATEGA_API_BASE=https://app.platega.io

# Инфраструктура (вне кода): панель и Node на нестандартных портах — закрыть в фаерволе,
# оставить только 80/443 на edge (Cloudflare) и origin от CF; прямой доступ по IP обходит WAF.
